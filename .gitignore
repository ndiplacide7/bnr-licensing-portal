# ───────────────────────────────────
# SECURITY — never commit these, ever
# ───────────────────────────────────
.env
.env.*
!.env.example          # the example template IS committed — it has no real values
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets/
config/secrets/


# ─────
# MAVEN
# ─────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven wrapper (keep the jar, ignore the download marker)
.mvn/wrapper/maven-wrapper.properties.bak

# Local Maven settings override (may contain credentials)
.mvn/jvm.config


# ──────────────
# INTELLIJ IDEA
# ──────────────

# Project metadata — regenerated by IntelliJ on open
.idea/
*.iws
*.iml
*.ipr

# Shelf (local uncommitted changes stashed in IDE)
.idea/shelf/

# Workspace file contains local paths and window layout — personal, not shared
.idea/workspace.xml

# Task configuration (local TODO/task state)
.idea/tasks.xml

# Editor statistics (typing heatmaps etc.)
.idea/statistics.xml

# Usage statistics
.idea/usage.statistics.xml

# If you DO want to share some .idea files (run configs, code style),
# selectively un-ignore them like this:
# !.idea/runConfigurations/
# !.idea/codeStyles/


# ───────────────────
# macOS SYSTEM FILES
# ───────────────────

# Finder metadata — created in every folder you open in Finder
.DS_Store
.DS_Store?
._*

# Spotlight index
.Spotlight-V100

# Trash
.Trashes
.fseventsd

# Volume icon
.VolumeIcon.icns

# Icon file with a carriage return (yes, this is a real thing on Mac)
Icon

# Time Machine
.TemporaryItems


# ─────
# JAVA
# ─────

# Compiled class files
*.class

# Log files
*.log
*.log.*
logs/

# BlueJ
*.ctxt

# Mobile Tools for Java
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*


# ────────────
# SPRING BOOT
# ────────────

# Spring Boot application PID file (created at runtime)
application.pid
spring.pid

# Uploaded files — simulated local storage for this project
uploads/
uploads-dev/
uploads-prod/

# Production config (never committed — values come from env vars)
src/main/resources/application-prod.yml


# ───────
# DOCKER
# ───────

# Docker override file is for local customisation, not shared config
docker-compose.override.yml


# ────────
# DATABASE
# ────────

# Local PostgreSQL data directory if ever mounted directly
postgres-data/
pgdata/

# DataGrip / DBeaver local config (contains connection passwords)
*.dsn
.dbtools/


# ───────────────────
# TESTING & COVERAGE
# ───────────────────

# JaCoCo coverage reports (generated on build)
**/jacoco.exec
**/jacoco/

# Surefire test reports (in target/, already covered, but explicit is clear)
**/surefire-reports/

# Testcontainers reuse file (local dev optimisation — not shared)
.testcontainers.properties


# ──────────────────────────────────
# EDITORS & OS (generic safety net)
# ──────────────────────────────────

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.emacs.desktop
.emacs.desktop.lock

# Visual Studio Code
.vscode/
!.vscode/extensions.json   # sharing recommended extensions is OK

# Nano backup
*.save

# JetBrains Rider (On Windows)
.idea/rider/


# ──────
# MISC
# ──────

# Patch files
*.patch
*.orig

# Checkstyle cache
.checkstyle

# PMD cache
.pmd